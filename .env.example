# ============================================================
#  AI Software Factory — client environment template
#  Copy this file to `.env.local` and fill in YOUR own keys.
#  These are PLACEHOLDERS — never commit real keys to git.
# ============================================================

# --- CORE AI BRAIN (required for credit letters, website builder, ask bar) ---
# Get it: https://console.anthropic.com  (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6            # default model id

# --- FREE CLIP BRAIN (optional, for the Clip Engine moment-picking) ---
# Get it free: https://build.nvidia.com  (NVIDIA NIM / MiniMax)
NVIDIA_API_KEY=nvapi-your-free-key-here
# Get it free: https://console.groq.com  (Whisper transcription for clips)
GROQ_API_KEY=gsk_your-groq-key-here

# --- WEBSITE PUBLISHING (required for the Build-a-Website play) ---
# Get it: Vercel dashboard -> Storage -> Blob -> Read/Write token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here

# --- PAYMENTS / CREDIT WALLET (required to charge clients) ---
# Get it: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
# Price IDs from your Stripe products:
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ELITE=price_xxx

# --- AUTO-POST CLIPS TO SOCIAL (optional, Clip Engine -> IG/TikTok) ---
# Get it: your Zernio account
ZERNIO_API_KEY=your-zernio-api-key
ZERNIO_WEBHOOK_SECRET=your-zernio-webhook-secret

# --- CERTIFIED MAIL (optional, Fix Credit -> mail dispute letters) ---
# Get it: your LetterStream account
LETTERSTREAM_API_ID=your-letterstream-id
LETTERSTREAM_API_KEY=your-letterstream-key

# --- DATABASE / AUTH (optional, if your build uses Supabase) ---
# Get it: https://supabase.com  -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AD TRACKING (optional) ---
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
META_CAPI_ACCESS_TOKEN=your-capi-token

# --- APP CONFIG ---
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Your Brand
AUTH_SECRET=generate-a-long-random-string
CRON_SECRET=generate-a-long-random-string
